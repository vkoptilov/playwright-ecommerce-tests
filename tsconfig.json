{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "*": ["*"]
    }
  },
  "include": [
    "tests/**/*",
    "pages/**/*",
    "api/**/*",
    "fixtures/**/*",
    "data/**/*",
    "utils/**/*"
  ]
}